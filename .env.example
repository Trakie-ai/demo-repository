# Relay Server
ANTHROPIC_API_KEY=sk-ant-...         # Claude Vision API key
PORT=3001                            # Relay server port (default 3001)
CORS_ORIGIN=http://localhost:3000    # Allowed origin for Socket.IO

# Mobile PWA (prefix with NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_RELAY_URL=http://localhost:3001

# Chrome Extension
RELAY_URL=http://localhost:3001      # Relay WebSocket endpoint
MOBILE_URL=http://localhost:3000     # Mobile PWA URL for QR generation
