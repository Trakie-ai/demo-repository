ANTHROPIC_API_KEY=sk-ant-...
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Trakie API base — used to verify extension tokens. Default: https://trakie.ai
TRAKIE_API_URL=https://trakie.ai

# Shared secret for /api/extension/verify. Must match RELAY_SHARED_SECRET in
# trakie-ai's environment. Generate with: openssl rand -base64 32
RELAY_SHARED_SECRET=
